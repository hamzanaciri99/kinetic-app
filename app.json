{
  "expo": {
    "name": "kinetic-app",
    "slug": "kinetic-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Kinetic uses your camera to capture progress photos.",
        "NSPhotoLibraryUsageDescription": "Kinetic uses your photo library to add progress photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#091F35",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.kineticapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Kinetic uses your camera to capture progress photos.",
          "photosPermission": "Kinetic uses your photo library to add progress photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kinetic uses your camera to scan barcodes and food photos."
        }
      ]
    ]
  }
}
